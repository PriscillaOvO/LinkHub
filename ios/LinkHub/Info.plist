<?xml version="1.0" encoding="UTF-8"?>
<!--
  Base Info.plist. The local-network consent string and the _linkhub._tcp
  Bonjour allow-list are also injected by project.yml; they are repeated here so
  the values are visible/editable even when the project is generated by Xcode
  directly rather than XcodeGen. Without both keys, NetService discovery on
  iOS 14+ returns nothing and no permission prompt is shown.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDisplayName</key>
    <string>LinkHub</string>
    <key>NSLocalNetworkUsageDescription</key>
    <string>LinkHub uses the local network to discover and securely connect to your nearby trusted devices.</string>
    <key>NSBonjourServices</key>
    <array>
        <string>_linkhub._tcp</string>
    </array>
</dict>
</plist>
